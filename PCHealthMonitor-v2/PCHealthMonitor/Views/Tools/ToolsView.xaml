<Page x:Class="PCHealthMonitor.Views.Tools.ToolsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBaseBrush}"
      Title="Tools">

    <ScrollViewer Padding="24,20,24,24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Tools" Style="{StaticResource TextH1Style}" VerticalAlignment="Center"/>
                    <ToggleButton x:Name="Info_Tools"
                                  Width="22" Height="22" Margin="10,0,0,0"
                                  VerticalAlignment="Center" Cursor="Hand"
                                  ToolTip="What are Tools?">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd" Width="22" Height="22" CornerRadius="11"
                                                    BorderBrush="{StaticResource BlueBrush}" BorderThickness="1.5"
                                                    Background="Transparent">
                                                <TextBlock Text="i" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontStyle="Italic" FontSize="12" FontWeight="Bold"
                                                           FontFamily="Georgia, serif"
                                                           Foreground="{StaticResource BlueBrush}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueGlowBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueGlowBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <Popup PlacementTarget="{Binding ElementName=Info_Tools}"
                           Placement="Bottom"
                           IsOpen="{Binding IsChecked, ElementName=Info_Tools}"
                           StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border CornerRadius="10" Padding="18,14" MaxWidth="360"
                                Background="{StaticResource BgCard2Brush}"
                                BorderBrush="{StaticResource BlueBrush}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="🔧  What are Tools?"
                                           Foreground="{StaticResource BlueBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource SubTextBrush}"><Run FontWeight="SemiBold" Foreground="White" Text="Driver Audit"/><Run Text=" scans installed drivers and flags outdated or unsigned entries that may cause system instability or security vulnerabilities."/></TextBlock>
                                    <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource SubTextBrush}"><Run FontWeight="SemiBold" Foreground="White" Text="Auto-Schedule Cleanup"/><Run Text=" lets you configure automatic junk cleaning on a recurring interval — so your PC stays clean without manual effort."/></TextBlock>
                                    <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource SubTextBrush}"><Run FontWeight="SemiBold" Foreground="White" Text="Export Report"/><Run Text=" (Pro) generates a full "/><Run FontWeight="SemiBold" Foreground="White" Text="CSV or HTML system health report"/><Run Text=" including 24-hour metric history, ready to print or share."/></TextBlock>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </StackPanel>

            <!-- ── Driver Audit ──────────────────────────────────────── -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Driver Audit" Style="{StaticResource TextH3Style}"/>
                            <TextBlock Text="{Binding DriverStatus}"
                                       Style="{StaticResource TextCaptionStyle}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Scan Drivers"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding ScanDriversCommand}"
                                Width="130" VerticalAlignment="Center"/>
                    </Grid>

                    <DataGrid ItemsSource="{Binding FlaggedDrivers}"
                              Style="{StaticResource DarkDataGridStyle}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              MaxHeight="280">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Status"  Binding="{Binding Status}"      Width="90"/>
                            <DataGridTextColumn Header="Driver"  Binding="{Binding Name}"         Width="*" MinWidth="160"/>
                            <DataGridTextColumn Header="Version" Binding="{Binding Version}"      Width="110"/>
                            <DataGridTextColumn Header="Date"    Binding="{Binding Date}"         Width="100"/>
                            <DataGridTextColumn Header="Class"   Binding="{Binding DeviceClass}"  Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- ── Auto-Schedule ────────────────────────────────────── -->
            <Border Grid.Row="4" Style="{StaticResource CardStyle}">
                <StackPanel>

                    <!-- Title row with PRO badge + enable toggle -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: title + PRO badge -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Auto-Schedule Cleanup"
                                       Style="{StaticResource TextH3Style}"
                                       Margin="0,0,10,0"/>
                            <Border CornerRadius="4" Padding="8,2" VerticalAlignment="Center"
                                    Background="{StaticResource BlueGlowBrush}">
                                <TextBlock Text="PRO" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BlueBrush}"/>
                            </Border>
                        </StackPanel>

                        <!-- Right: enable toggle -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Enabled"
                                       Style="{StaticResource TextBodySmStyle}"
                                       Foreground="{StaticResource SubTextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <ToggleButton Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding ScheduleEnabled}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Description -->
                    <TextBlock Text="Automatically cleans junk files on a recurring schedule. Set your preferred frequency and time — cleanup runs silently in the background."
                               Style="{StaticResource TextCaptionStyle}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"/>

                    <!-- Schedule settings grid -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Frequency (ComboBox) -->
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="🗓  " FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="Frequency"
                                           Style="{StaticResource TextCaptionStyle}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <ComboBox Style="{StaticResource DarkComboBoxStyle}"
                                      SelectedValue="{Binding ScheduleIntervalOption, Mode=TwoWay}"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Content="Daily"          Tag="1"/>
                                <ComboBoxItem Content="Every 3 days"   Tag="3"/>
                                <ComboBoxItem Content="Weekly"         Tag="7"/>
                                <ComboBoxItem Content="Every 2 weeks"  Tag="14"/>
                                <ComboBoxItem Content="Monthly"        Tag="30"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Time of day -->
                        <StackPanel Grid.Column="2">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="⏰  " FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="Start time (HH:MM)"
                                           Style="{StaticResource TextCaptionStyle}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBox Text="{Binding ScheduleTime, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DarkTextBoxStyle}"
                                     Tag="e.g. 02:00"/>
                        </StackPanel>
                    </Grid>

                    <!-- Status banner -->
                    <Border CornerRadius="8" Padding="14,10" Margin="0,16,0,0"
                            Background="{StaticResource BgCard2Brush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋  " FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ScheduleStatus}"
                                       Style="{StaticResource TextCaptionStyle}"
                                       Foreground="{StaticResource GreenBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="Save Schedule"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SaveScheduleCommand}"
                                Width="150" Margin="0,0,12,0"/>
                        <Button Content="Remove Schedule"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding DeleteScheduleCommand}"
                                Width="160"/>
                    </StackPanel>

                </StackPanel>
            </Border>
            <!-- ── Pro: Export Report ────────────────────────────────── -->
            <Border Grid.Row="6" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Export Report" Style="{StaticResource TextH3Style}" Margin="0,0,12,0"/>
                        <Border CornerRadius="4" Padding="8,2" VerticalAlignment="Center"
                                Background="{StaticResource BlueGlowBrush}">
                            <TextBlock Text="PRO" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource BlueBrush}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Export a full system health report with 24-hour history data."
                               Style="{StaticResource TextCaptionStyle}" Margin="0,2,0,16"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Export CSV"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ExportCsvCommand}"
                                Width="130" Margin="0,0,12,0"/>
                        <Button Content="Export HTML / PDF"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding ExportHtmlCommand}"
                                Width="160"/>
                    </StackPanel>

                    <TextBlock Text="{Binding ExportStatus}"
                               Style="{StaticResource TextCaptionStyle}"
                               Foreground="{StaticResource GreenBrush}"/>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</Page>
