<Page x:Class="PCHealthMonitor.Views.Tools.ToolsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBaseBrush}"
      Title="Tools">

    <ScrollViewer Padding="24,20,24,24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="Tools" Style="{StaticResource TextH1Style}"/>

            <!-- ── Driver Audit ──────────────────────────────────────── -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Driver Audit" Style="{StaticResource TextH3Style}"/>
                            <TextBlock Text="{Binding DriverStatus}"
                                       Style="{StaticResource TextCaptionStyle}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Scan Drivers"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding ScanDriversCommand}"
                                Width="130" VerticalAlignment="Center"/>
                    </Grid>

                    <DataGrid ItemsSource="{Binding FlaggedDrivers}"
                              Style="{StaticResource DarkDataGridStyle}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              MaxHeight="280">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Status"  Binding="{Binding Status}"      Width="90"/>
                            <DataGridTextColumn Header="Driver"  Binding="{Binding Name}"         Width="*" MinWidth="160"/>
                            <DataGridTextColumn Header="Version" Binding="{Binding Version}"      Width="110"/>
                            <DataGridTextColumn Header="Date"    Binding="{Binding Date}"         Width="100"/>
                            <DataGridTextColumn Header="Class"   Binding="{Binding DeviceClass}"  Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- ── Auto-Schedule ────────────────────────────────────── -->
            <Border Grid.Row="4" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Auto-Schedule Cleanup" Style="{StaticResource TextH3Style}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Enable toggle -->
                        <StackPanel Grid.Row="0" Grid.ColumnSpan="2"
                                    Orientation="Horizontal" VerticalAlignment="Center">
                            <ToggleButton Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding ScheduleEnabled}"/>
                            <TextBlock Text="Enable automatic cleanup" Style="{StaticResource TextBodyStyle}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Interval -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Run every (days)" Style="{StaticResource TextCaptionStyle}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding ScheduleIntervalDays}"
                                     Style="{StaticResource DarkTextBoxStyle}"/>
                        </StackPanel>

                        <!-- Time -->
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="At time (HH:MM)" Style="{StaticResource TextCaptionStyle}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding ScheduleTime}"
                                     Style="{StaticResource DarkTextBoxStyle}"/>
                        </StackPanel>

                        <!-- Status -->
                        <TextBlock Grid.Row="4" Grid.ColumnSpan="2"
                                   Text="{Binding ScheduleStatus}"
                                   Style="{StaticResource TextCaptionStyle}"
                                   Foreground="{StaticResource GreenBrush}"/>

                        <!-- Buttons -->
                        <StackPanel Grid.Row="6" Grid.ColumnSpan="2"
                                    Orientation="Horizontal">
                            <Button Content="Save Schedule"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding SaveScheduleCommand}" Width="140"/>
                            <Button Content="Remove Schedule"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding DeleteScheduleCommand}" Width="160"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
