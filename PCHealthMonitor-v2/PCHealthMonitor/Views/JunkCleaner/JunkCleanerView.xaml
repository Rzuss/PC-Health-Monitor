<Page x:Class="PCHealthMonitor.Views.JunkCleaner.JunkCleanerView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBaseBrush}"
      Title="Junk Cleaner">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Junk Cleaner" Style="{StaticResource TextH1Style}" VerticalAlignment="Center"/>
                    <ToggleButton x:Name="Info_Junk_Cleaner"
                                  Width="22" Height="22" Margin="10,0,0,0"
                                  VerticalAlignment="Center" Cursor="Hand"
                                  ToolTip="What is Junk Cleaner?">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd" Width="22" Height="22" CornerRadius="11"
                                                    BorderBrush="{StaticResource BlueBrush}" BorderThickness="1.5"
                                                    Background="Transparent">
                                                <TextBlock Text="i" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontStyle="Italic" FontSize="12" FontWeight="Bold"
                                                           FontFamily="Georgia, serif"
                                                           Foreground="{StaticResource BlueLightBrush}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueGlowBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueGlowBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <Popup PlacementTarget="{Binding ElementName=Info_Junk_Cleaner}"
                           Placement="Bottom"
                           IsOpen="{Binding IsChecked, ElementName=Info_Junk_Cleaner}"
                           StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border CornerRadius="10" Padding="18,14" MaxWidth="360"
                                Background="{StaticResource BgCard2Brush}"
                                BorderBrush="{StaticResource BlueBrush}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="🗑  What is Junk Cleaner?"
                                           Foreground="{StaticResource BlueLightBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource SubTextBrush}"><Run Text="Scans for "/><Run FontWeight="SemiBold" Foreground="White" Text="temporary files, browser cache, Windows Update leftovers"/><Run Text=" and other safe-to-delete data that accumulates over time."/></TextBlock>
                                    <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource SubTextBrush}"><Run FontWeight="SemiBold" Foreground="White" Text="Check"/><Run Text=" the categories you want to remove, then click "/><Run FontWeight="SemiBold" Foreground="White" Text="Clean"/><Run Text=". Only files flagged as temporary by Windows are targeted — your documents and installed apps are never touched."/></TextBlock>
                                    <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource GreenBrush}" Margin="0,8,0,0">✓  Safe to run at any time. Average cleanup frees 1–5 GB on most systems.</TextBlock>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource TextCaptionStyle}" Margin="0,2,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Scan"
                    AutomationProperties.AutomationId="JunkScanBtn"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding ScanCommand}" Width="90"
                    VerticalAlignment="Center"/>
            <Button Grid.Column="3" Content="Clean"
                    AutomationProperties.AutomationId="JunkCleanBtn"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding CleanCommand}" Width="110"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- Categories list -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding Categories}"
                      AutomationProperties.AutomationId="JunkCategoriesGrid"
                      Style="{StaticResource DarkDataGridStyle}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="False">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="" Binding="{Binding Selected}" Width="44"/>
                    <DataGridTextColumn Header="Category"   Binding="{Binding Name}"        Width="*" MinWidth="180"/>
                    <DataGridTextColumn Header="Files"      Binding="{Binding FileCount}"   Width="80"/>
                    <DataGridTextColumn Header="Size"       Binding="{Binding SizeDisplay}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer total -->
        <Border Grid.Row="4" Style="{StaticResource Card2Style}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Total to clean: " Style="{StaticResource TextBodyStyle}"/>
                    <TextBlock Text="{Binding TotalDisplay}"
                               Style="{StaticResource TextBodyStyle}"
                               Foreground="{StaticResource RedBrush}" FontWeight="SemiBold"/>
                </StackPanel>
                <ProgressBar Grid.Column="1" Width="200" Height="6"
                             Style="{StaticResource DarkProgressBarStyle}"
                             IsIndeterminate="{Binding IsBusy}"
                             Foreground="{StaticResource GreenBrush}"
                             VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Page>

