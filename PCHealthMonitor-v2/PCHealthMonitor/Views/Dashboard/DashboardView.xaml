<Page x:Class="PCHealthMonitor.Views.Dashboard.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:PCHealthMonitor.ViewModels"
      Background="{StaticResource BgBaseBrush}"
      Title="Dashboard">

    <ScrollViewer Padding="28,22,28,28">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Header row -->
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>   <!-- Score + mini gauges -->
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>   <!-- Bottom cards: VIP, Quick Actions, Alerts -->
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>   <!-- PRO: Performance History charts -->
            </Grid.RowDefinitions>

            <!-- ─── Header ──────────────────────────────────────────────── -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Dashboard" Style="{StaticResource TextH1Style}" VerticalAlignment="Center"/>
                    <ToggleButton x:Name="Info_Dashboard"
                                  Width="22" Height="22" Margin="10,0,0,0"
                                  VerticalAlignment="Center" Cursor="Hand"
                                  ToolTip="What is the Dashboard?">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd" Width="20" Height="20" CornerRadius="10"
                                                    BorderBrush="{StaticResource BlueLightBrush}" BorderThickness="1.2"
                                                    Background="Transparent">
                                                <TextBlock Text="i" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontStyle="Italic" FontSize="11" FontWeight="Bold"
                                                           FontFamily="Georgia, serif"
                                                           Foreground="{StaticResource BlueLightBrush}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueLightGlowBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueLightGlowBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <Popup PlacementTarget="{Binding ElementName=Info_Dashboard}"
                           Placement="Bottom"
                           IsOpen="{Binding IsChecked, ElementName=Info_Dashboard}"
                           StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border CornerRadius="8" Padding="16,12" MaxWidth="360"
                                Background="{StaticResource BgCard3Brush}"
                                BorderBrush="{StaticResource BlueLightBrush}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="What is the Dashboard?"
                                           Foreground="{StaticResource BlueLightBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource SubTextBrush}"><Run Text="The "/><Run FontWeight="SemiBold" Foreground="White" Text="Health Score"/><Run Text=" (0–100) is a real-time snapshot of your PC's wellbeing — factoring in CPU load, RAM pressure, disk usage, and startup overhead."/></TextBlock>
                                    <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource SubTextBrush}"><Run FontWeight="SemiBold" Foreground="White" Text="Live gauges"/><Run Text=" refresh every 2 seconds. Click "/><Run FontWeight="SemiBold" Foreground="White" Text="Scan Now"/><Run Text=" to run a diagnostic and surface any issues immediately."/></TextBlock>
                                    <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource SubTextBrush}" Margin="0,8,0,0">Pro users also see a historical chart (1h / 24h / 7d / 30d) below the gauges.</TextBlock>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
                    <TextBlock x:Name="LastScanText"
                               Text="Last scan: never"
                               Style="{StaticResource TextCaptionStyle}"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        x:Name="ScanBtn"
                        AutomationProperties.AutomationId="DashboardScanBtn"
                        Content="Scan Now"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="120"
                        VerticalAlignment="Center"
                        Click="ScanBtn_Click"/>
            </Grid>

            <!-- ─── Health Score + Mini Gauges row ──────────────────────── -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270"/>   <!-- Score ring -->
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>     <!-- Mini gauges -->
                </Grid.ColumnDefinitions>

                <!-- Health Score Arc Card -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="220"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Health Score"
                                   Style="{StaticResource TextH3Style}"
                                   Margin="0,0,0,16"/>

                        <!-- Arc gauge canvas -->
                        <Canvas Grid.Row="1" Width="200" Height="200"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- Background track arc -->
                            <Path x:Name="ArcTrack"
                                  Stroke="{StaticResource BgCard3Brush}"
                                  StrokeThickness="14"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Fill="Transparent">
                                <Path.Data>
                                    <PathGeometry>
                                        <PathFigure StartPoint="20,160" IsClosed="False">
                                            <ArcSegment x:Name="TrackArc"
                                                        Point="180,160"
                                                        Size="80,80"
                                                        SweepDirection="Clockwise"
                                                        IsLargeArc="True"/>
                                        </PathFigure>
                                    </PathGeometry>
                                </Path.Data>
                            </Path>

                            <!-- Foreground value arc -->
                            <Path x:Name="ArcValue"
                                  StrokeThickness="14"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Fill="Transparent">
                                <Path.Stroke>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#4CC2FF" Offset="0"/>
                                        <GradientStop Color="#0067C0" Offset="1"/>
                                    </LinearGradientBrush>
                                </Path.Stroke>
                                <Path.Data>
                                    <PathGeometry>
                                        <PathFigure x:Name="ArcFigure" StartPoint="20,160" IsClosed="False">
                                            <ArcSegment x:Name="ValueArc"
                                                        Point="20.001,160"
                                                        Size="80,80"
                                                        SweepDirection="Clockwise"
                                                        IsLargeArc="False"/>
                                        </PathFigure>
                                    </PathGeometry>
                                </Path.Data>
                            </Path>

                            <!-- Score number center -->
                            <StackPanel Canvas.Left="55" Canvas.Top="68" Width="90">
                                <TextBlock x:Name="ScoreNumber"
                                           AutomationProperties.AutomationId="DashboardScoreNumber"
                                           Text="--"
                                           Style="{StaticResource TextScoreStyle}"
                                           FontSize="48"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="ScoreGrade"
                                           Text="Scanning..."
                                           Style="{StaticResource TextCaptionStyle}"
                                           HorizontalAlignment="Center"
                                           Margin="0,-4,0,0"/>
                            </StackPanel>
                        </Canvas>

                        <!-- Score details -->
                        <UniformGrid Grid.Row="2" Rows="1" Columns="2" Margin="0,12,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="IssueCount"
                                           Text="--"
                                           Style="{StaticResource TextMetricStyle}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Issues Found"
                                           Style="{StaticResource TextCaptionStyle}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="JunkSize"
                                           Text="-- MB"
                                           Style="{StaticResource TextMetricStyle}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Junk Files"
                                           Style="{StaticResource TextCaptionStyle}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </UniformGrid>
                    </Grid>
                </Border>

                <!-- Mini Gauges stack -->
                <StackPanel Grid.Column="2">
                    <!-- CPU Gauge Card -->
                    <Border Style="{StaticResource Card2Style}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="CPU" Style="{StaticResource TextLabelStyle}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       x:Name="CpuTempLabel"
                                       Text="-- °C"
                                       Style="{StaticResource TextCaptionStyle}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       x:Name="CpuLoadLabel"
                                       Text="--%"
                                       Style="{StaticResource TextH3Style}"/>

                            <ProgressBar Grid.Row="4" Grid.ColumnSpan="2"
                                         x:Name="CpuBar"
                                         Style="{StaticResource DarkProgressBarStyle}"
                                         Value="0" Maximum="100"/>
                        </Grid>
                    </Border>

                    <!-- RAM Gauge Card -->
                    <Border Style="{StaticResource Card2Style}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="MEMORY" Style="{StaticResource TextLabelStyle}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       x:Name="RamGbLabel"
                                       Text="-- / -- GB"
                                       Style="{StaticResource TextCaptionStyle}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       x:Name="RamLoadLabel"
                                       Text="--%"
                                       Style="{StaticResource TextH3Style}"/>

                            <ProgressBar Grid.Row="4" Grid.ColumnSpan="2"
                                         x:Name="RamBar"
                                         Style="{StaticResource DarkProgressBarStyle}"
                                         Foreground="{StaticResource PurpleBrush}"
                                         Value="0" Maximum="100"/>
                        </Grid>
                    </Border>

                    <!-- Disk Gauge Card -->
                    <Border Style="{StaticResource Card2Style}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="DISK ACTIVITY" Style="{StaticResource TextLabelStyle}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       x:Name="DiskLoadLabel"
                                       Text="--%"
                                       Style="{StaticResource TextH3Style}"/>

                            <ProgressBar Grid.Row="4" Grid.ColumnSpan="2"
                                         x:Name="DiskBar"
                                         Style="{StaticResource DarkProgressBarStyle}"
                                         Foreground="{StaticResource YellowBrush}"
                                         Value="0" Maximum="100"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ─── Bottom Row: VIP Card + Quick Actions + Alerts ──────── -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- VIP Card -->
                <Border Grid.Column="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0C1A2E" Offset="0"/>
                            <GradientStop Color="#0A1628" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border BorderBrush="#2A4CC2FF" BorderThickness="1" CornerRadius="8" Padding="20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Path Width="16" Height="16" Margin="0,0,8,0"
                                      Data="M 8 1 L 5 7 L 1 7 L 5 11 L 3.5 15 L 8 11.5 L 12.5 15 L 11 11 L 15 7 L 11 7 Z"
                                      Fill="#4CC2FF" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="VIP BOOST MODE"
                                           Style="{StaticResource TextH3Style}"
                                           FontSize="14"
                                           Foreground="{StaticResource BlueLightBrush}"/>
                            </StackPanel>
                            <TextBlock x:Name="VipStatusText"
                                       Text="No VIP session active"
                                       Style="{StaticResource TextBodyStyle}"
                                       Foreground="{StaticResource SubTextBrush}"
                                       Margin="0,0,0,12"/>
                            <Button Content="Activate Boost"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="ActivateBoostBtn_Click"/>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Quick Actions -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Quick Actions"
                                   Style="{StaticResource TextH3Style}"
                                   Margin="0,0,0,12"/>
                        <Button Content="Clean Junk Files"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,8"
                                Click="QuickClean_Click"/>
                        <Button Content="Optimize Startup"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,8"
                                Click="QuickStartup_Click"/>
                        <Button Content="Run Disk Health Check"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Click="QuickDiskHealth_Click"/>
                    </StackPanel>
                </Border>

                <!-- System Alerts -->
                <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="System Alerts"
                                   Style="{StaticResource TextH3Style}"
                                   Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding Alerts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BgCard2Brush}"
                                            CornerRadius="8" Padding="12,8" Margin="0,0,0,6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontSize="16" Margin="0,0,8,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Message}"
                                                       Style="{StaticResource TextBodySmStyle}"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Shown only when Alerts list is empty -->
                        <TextBlock Text="Run a scan to check system health"
                                   HorizontalAlignment="Center"
                                   Margin="0,8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextCaptionStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Alerts.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ─── PRO: Performance History ───────────────────────────── -->
            <Border Grid.Row="6" Style="{StaticResource CardStyle}"
                    x:Name="HistoryCard">
                <StackPanel>

                    <!-- Title + PRO badge + time range buttons -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Performance History"
                                       Style="{StaticResource TextH3Style}"
                                       Margin="0,0,10,0"/>
                            <Border CornerRadius="4" Padding="8,2" VerticalAlignment="Center"
                                    Background="{StaticResource BlueLightGlowBrush}">
                                <TextBlock Text="PRO" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BlueLightBrush}"/>
                            </Border>
                        </StackPanel>

                        <!-- Time range selector -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="Btn1H"  Content="1H"  Width="40" Margin="0,0,4,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="TimeRangeBtn_Click" Tag="1"/>
                            <Button x:Name="Btn24H" Content="24H" Width="44" Margin="0,0,4,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="TimeRangeBtn_Click" Tag="24"/>
                            <Button x:Name="Btn7D"  Content="7D"  Width="40" Margin="0,0,4,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="TimeRangeBtn_Click" Tag="168"/>
                            <Button x:Name="Btn30D" Content="30D" Width="44"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="TimeRangeBtn_Click" Tag="720"/>
                        </StackPanel>
                    </Grid>

                    <!-- Legend -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource BlueLightBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="CPU" Style="{StaticResource TextCaptionStyle}" Margin="0,0,16,0"/>
                        <Ellipse Width="8" Height="8" Fill="{StaticResource GreenBrush}"    Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="RAM" Style="{StaticResource TextCaptionStyle}" Margin="0,0,16,0"/>
                        <Ellipse Width="8" Height="8" Fill="{StaticResource YellowBrush}"   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Disk" Style="{StaticResource TextCaptionStyle}"/>
                    </StackPanel>

                    <!-- Chart canvas -->
                    <Border CornerRadius="6" Background="{StaticResource BgCard3Brush}"
                            Height="130" ClipToBounds="True"
                            SizeChanged="ChartCanvas_SizeChanged">
                        <Canvas x:Name="ChartCanvas">

                            <!-- Grid lines (horizontal at 25%, 50%, 75%) -->
                            <Line x:Name="GridLine75" Stroke="{StaticResource BorderBrush}"
                                  StrokeThickness="1" StrokeDashArray="3,4" Opacity="0.5"/>
                            <Line x:Name="GridLine50" Stroke="{StaticResource BorderBrush}"
                                  StrokeThickness="1" StrokeDashArray="3,4" Opacity="0.5"/>
                            <Line x:Name="GridLine25" Stroke="{StaticResource BorderBrush}"
                                  StrokeThickness="1" StrokeDashArray="3,4" Opacity="0.5"/>

                            <!-- Y-axis labels -->
                            <TextBlock x:Name="LabelTop"    Canvas.Left="4" Canvas.Top="2"
                                       Text="100%" Style="{StaticResource TextCaptionStyle}"
                                       FontSize="9" Opacity="0.5"/>
                            <TextBlock x:Name="Label75"     Canvas.Left="4"
                                       Text="75%"  Style="{StaticResource TextCaptionStyle}"
                                       FontSize="9" Opacity="0.5"/>
                            <TextBlock x:Name="Label50"     Canvas.Left="4"
                                       Text="50%"  Style="{StaticResource TextCaptionStyle}"
                                       FontSize="9" Opacity="0.5"/>
                            <TextBlock x:Name="Label25"     Canvas.Left="4"
                                       Text="25%"  Style="{StaticResource TextCaptionStyle}"
                                       FontSize="9" Opacity="0.5"/>

                            <!-- Chart polylines -->
                            <Polyline x:Name="CpuLine"
                                      Stroke="{StaticResource BlueLightBrush}"
                                      StrokeThickness="1.5"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"/>
                            <Polyline x:Name="RamLine"
                                      Stroke="{StaticResource GreenBrush}"
                                      StrokeThickness="1.5"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"/>
                            <Polyline x:Name="DiskLine"
                                      Stroke="{StaticResource YellowBrush}"
                                      StrokeThickness="1.5"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"/>

                            <!-- "Not enough data yet" placeholder -->
                            <TextBlock x:Name="NoDataLabel"
                                       Text="Collecting data… check back in a minute."
                                       Style="{StaticResource TextCaptionStyle}"
                                       Foreground="{StaticResource SubTextBrush}"
                                       Canvas.Left="0" Canvas.Top="50"
                                       TextAlignment="Center"/>
                        </Canvas>
                    </Border>

                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</Page>
