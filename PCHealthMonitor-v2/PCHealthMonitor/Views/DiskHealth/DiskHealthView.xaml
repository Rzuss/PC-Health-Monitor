<Page x:Class="PCHealthMonitor.Views.DiskHealth.DiskHealthView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBaseBrush}"
      Title="System Info">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>      <!-- Content -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="System Info" Style="{StaticResource TextH1Style}"/>
            <TextBlock Text="Hardware overview for this machine"
                       Style="{StaticResource TextCaptionStyle}" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Loading state -->
        <TextBlock Grid.Row="2"
                   Text="Loading system information..."
                   Style="{StaticResource TextCaptionStyle}"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibleConverter}}"/>

        <!-- Content — visible when loaded -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToCollapsedConverter}}">
            <StackPanel>

                <!-- ── Row 1: CPU · RAM · OS ─────────────────────────── -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- CPU card -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="⚙" FontSize="16" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Processor"
                                           Style="{StaticResource TextH3Style}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Snapshot.CpuName}"
                                       Style="{StaticResource TextBodyStyle}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding Snapshot.CpuCoreDisplay}"
                                       Style="{StaticResource TextCaptionStyle}"
                                       Margin="0,0,0,12"/>
                            <!-- Live load -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Load" Style="{StaticResource TextCaptionStyle}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Snapshot.CpuLoadDisplay}"
                                           Style="{StaticResource TextBodySmStyle}"
                                           Foreground="{StaticResource BlueBrush}"
                                           FontWeight="SemiBold"/>
                            </Grid>
                            <ProgressBar Value="{Binding Snapshot.CpuLoad, Mode=OneWay}"
                                         Maximum="100" Height="4"
                                         Style="{StaticResource DarkProgressBarStyle}"
                                         Margin="0,0,0,10"/>
                            <!-- Temperature -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Temp: "
                                           Style="{StaticResource TextCaptionStyle}"/>
                                <TextBlock Text="{Binding Snapshot.CpuTempDisplay}"
                                           Style="{StaticResource TextCaptionStyle}"
                                           Foreground="{StaticResource YellowBrush}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- RAM card -->
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="▦" FontSize="16" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Memory"
                                           Style="{StaticResource TextH3Style}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Snapshot.RamDisplay}"
                                       Style="{StaticResource TextBodyStyle}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding Snapshot.RamSpeedDisplay}"
                                       Style="{StaticResource TextCaptionStyle}"
                                       Margin="0,0,0,12"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Usage" Style="{StaticResource TextCaptionStyle}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Snapshot.RamLoadPct, StringFormat={}{0}%}"
                                           Style="{StaticResource TextBodySmStyle}"
                                           Foreground="{StaticResource GreenBrush}"
                                           FontWeight="SemiBold"/>
                            </Grid>
                            <ProgressBar Value="{Binding Snapshot.RamLoadPct, Mode=OneWay}"
                                         Maximum="100" Height="4"
                                         Style="{StaticResource DarkProgressBarStyle}"
                                         Margin="0,0,0,10"/>
                        </StackPanel>
                    </Border>

                    <!-- OS card -->
                    <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="🖥" FontSize="16" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Operating System"
                                           Style="{StaticResource TextH3Style}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Snapshot.OsDisplay}"
                                       Style="{StaticResource TextBodyStyle}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Uptime" Style="{StaticResource TextCaptionStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Snapshot.Uptime}"
                                           Style="{StaticResource TextBodySmStyle}"
                                           FontWeight="SemiBold"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Machine" Style="{StaticResource TextCaptionStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Snapshot.MachineName}"
                                           Style="{StaticResource TextBodySmStyle}"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="User" Style="{StaticResource TextCaptionStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Snapshot.UserName}"
                                           Style="{StaticResource TextBodySmStyle}"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Arch" Style="{StaticResource TextCaptionStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Snapshot.Architecture}"
                                           Style="{StaticResource TextBodySmStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── Row 2: GPU ─────────────────────────────────────── -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="▣" FontSize="16" Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Graphics"
                                       Style="{StaticResource TextH3Style}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,24,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Snapshot.GpuName}"
                                   Style="{StaticResource TextBodyStyle}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Snapshot.GpuVramDisplay}"
                                   Style="{StaticResource TextCaptionStyle}"
                                   Foreground="{StaticResource BlueBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- ── Row 3: Storage drives ─────────────────────────── -->
                <Border Style="{StaticResource CardStyle}" Padding="0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="16,14,16,12">
                            <TextBlock Text="💾" FontSize="16" Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Storage"
                                       Style="{StaticResource TextH3Style}"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Snapshot.Drives}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,1,0,0"
                                            Padding="16,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Label + type -->
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Label}"
                                                           Style="{StaticResource TextBodyStyle}"
                                                           FontWeight="Medium"/>
                                                <StackPanel Orientation="Horizontal"
                                                            Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding DriveType}"
                                                               Style="{StaticResource TextCaptionStyle}"
                                                               Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding FileSystem}"
                                                               Style="{StaticResource TextCaptionStyle}"
                                                               Opacity="0.6"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Usage bar -->
                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,16,0">
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding SizeDisplay}"
                                                               Style="{StaticResource TextCaptionStyle}"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding UsedPct, StringFormat={}{0}%}"
                                                               Style="{StaticResource TextCaptionStyle}"
                                                               Foreground="{StaticResource BlueBrush}"/>
                                                </Grid>
                                                <ProgressBar Value="{Binding UsedPct, Mode=OneWay}"
                                                             Maximum="100" Height="5"
                                                             Style="{StaticResource DarkProgressBarStyle}"/>
                                            </StackPanel>

                                            <!-- Free space -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding FreeDisplay}"
                                                       Style="{StaticResource TextCaptionStyle}"
                                                       Foreground="{StaticResource GreenBrush}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
