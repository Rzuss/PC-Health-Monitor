<Page x:Class="PCHealthMonitor.Views.Settings.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBaseBrush}"
      Title="Settings">

    <ScrollViewer Padding="24,20,24,24">
        <StackPanel MaxWidth="680" HorizontalAlignment="Center">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Settings" Style="{StaticResource TextH1Style}" VerticalAlignment="Center"/>
                    <ToggleButton x:Name="Info_Settings"
                                  Width="22" Height="22" Margin="10,0,0,0"
                                  VerticalAlignment="Center" Cursor="Hand"
                                  ToolTip="What can I configure here?">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd" Width="22" Height="22" CornerRadius="11"
                                                    BorderBrush="{StaticResource BlueBrush}" BorderThickness="1.5"
                                                    Background="Transparent">
                                                <TextBlock Text="i" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontStyle="Italic" FontSize="12" FontWeight="Bold"
                                                           FontFamily="Georgia, serif"
                                                           Foreground="{StaticResource BlueLightBrush}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueGlowBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueGlowBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <Popup PlacementTarget="{Binding ElementName=Info_Settings}"
                           Placement="Bottom"
                           IsOpen="{Binding IsChecked, ElementName=Info_Settings}"
                           StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border CornerRadius="10" Padding="18,14" MaxWidth="360"
                                Background="{StaticResource BgCard2Brush}"
                                BorderBrush="{StaticResource BlueBrush}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="⚙  What can I configure here?"
                                           Foreground="{StaticResource BlueLightBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource SubTextBrush}"><Run FontWeight="SemiBold" Foreground="White" Text="Start with Windows"/><Run Text=" — launches PC Health Monitor automatically at login. "/><Run FontWeight="SemiBold" Foreground="White" Text="Minimize to Tray"/><Run Text=" — keeps it running silently in the system tray when you close the window."/></TextBlock>
                                    <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource SubTextBrush}"><Run FontWeight="SemiBold" Foreground="White" Text="Notifications"/><Run Text=" — receive a toast alert when an issue is detected. "/><Run FontWeight="SemiBold" Foreground="White" Text="Custom Alerts"/><Run Text=" (Pro) — set your own CPU &amp; RAM threshold percentages for personalised warnings."/></TextBlock>
                                    <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource SubTextBrush}"><Run Text="Use the "/><Run FontWeight="SemiBold" Foreground="White" Text="License"/><Run Text=" section to activate your Pro key or view your current plan."/></TextBlock>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </StackPanel>

            <!-- General -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="General" Style="{StaticResource TextH3Style}" Margin="0,0,0,16"/>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ToggleButton Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding StartWithWindows}"/>
                            <StackPanel>
                                <TextBlock Text="Start with Windows" Style="{StaticResource TextBodyStyle}"/>
                                <TextBlock Text="Launch automatically when you log in"
                                           Style="{StaticResource TextCaptionStyle}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ToggleButton Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding MinimizeToTray}"/>
                            <StackPanel>
                                <TextBlock Text="Minimize to system tray" Style="{StaticResource TextBodyStyle}"/>
                                <TextBlock Text="Keep running in background when window is closed"
                                           Style="{StaticResource TextCaptionStyle}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <ToggleButton Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding ShowNotifications}"/>
                            <StackPanel>
                                <TextBlock Text="Show notifications" Style="{StaticResource TextBodyStyle}"/>
                                <TextBlock Text="Alert you when issues are detected"
                                           Style="{StaticResource TextCaptionStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <Separator Margin="0,16"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Reset Defaults" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ResetCommand}" Width="140" Margin="0,0,12,0"/>
                        <Button Content="Save Settings"  Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SaveCommand}"  Width="140"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Pro: Custom Alerts — always visible; locked overlay for free users -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Custom Alerts" Style="{StaticResource TextH3Style}" Margin="0,0,12,0"/>
                        <Border CornerRadius="4" Padding="8,2" VerticalAlignment="Center"
                                Background="{StaticResource BlueLightGlowBrush}">
                            <TextBlock Text="PRO" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource BlueLightBrush}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Get a toast notification when CPU or RAM exceeds your threshold. Set to 0 to disable."
                               Style="{StaticResource TextCaptionStyle}" Margin="0,2,0,16"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- CPU threshold -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CPU Alert Threshold (%)" Style="{StaticResource TextCaptionStyle}" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                     Text="{Binding CpuAlertThreshold, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="0 = off, e.g. 90"/>
                        </StackPanel>

                        <!-- RAM threshold -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="RAM Alert Threshold (%)" Style="{StaticResource TextCaptionStyle}" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                     Text="{Binding RamAlertThreshold, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="0 = off, e.g. 85"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Style="{StaticResource TextCaptionStyle}" Foreground="{StaticResource SubTextBrush}">
                        <Run Text="Alerts are throttled to one per 5 minutes per metric. Save Settings to apply."/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- License / Activation -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>

                    <!-- Title row -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="License" Style="{StaticResource TextH3Style}" Margin="0,0,12,0"/>
                        <Border CornerRadius="4" Padding="8,2" VerticalAlignment="Center"
                                Background="{StaticResource BlueLightGlowBrush}"
                                Visibility="{Binding IsActivated, Converter={StaticResource BoolToVisibleConverter}}">
                            <TextBlock Text="PRO ACTIVE" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource BlueLightBrush}"/>
                        </Border>
                    </StackPanel>

                    <!-- Active Pro summary (shown when activated) -->
                    <Border CornerRadius="8" Padding="14,12"
                            Background="{StaticResource BlueLightGlowBrush}"
                            Margin="0,8,0,16"
                            Visibility="{Binding IsActivated, Converter={StaticResource BoolToVisibleConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="PC Health Monitor Pro" FontWeight="SemiBold"
                                           Foreground="{StaticResource BlueLightBrush}" FontSize="13"/>
                                <TextBlock Style="{StaticResource TextCaptionStyle}" Margin="0,2,0,0">
                                    <Run Text="All features unlocked · Historical Charts, Scheduled Cleanup, Export, Alerts"/>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Deactivate"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding DeactivateCommand}"
                                    Width="110" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Key entry panel (shown when NOT activated) -->
                    <StackPanel Visibility="{Binding IsActivated, Converter={StaticResource BoolToCollapsedConverter}}">
                        <TextBlock Margin="0,2,0,12"
                                   Style="{StaticResource TextCaptionStyle}">
                            <Run Text="Enter your license key to unlock Historical Charts, Scheduled Cleanup, PDF/CSV Export &amp; Custom Alerts.  "/>
                            <Hyperlink NavigateUri="https://rzuss.gumroad.com"
                                       RequestNavigate="Hyperlink_RequestNavigate"
                                       Foreground="{StaticResource BlueLightBrush}">
                                Get a key →
                            </Hyperlink>
                        </TextBlock>

                        <TextBlock Text="License Key" Style="{StaticResource TextCaptionStyle}" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="XXXX-XXXX-XXXX-XXXX">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource DarkTextBoxStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <Button Grid.Column="2"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding ActivateCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Activating…"
                                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibleConverter}}"/>
                                    <TextBlock Text="Activate"
                                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToCollapsedConverter}}"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!-- Status message (error = red, success/info = green) -->
                    <TextBlock Text="{Binding LicenseStatus}"
                               Margin="0,10,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource TextCaptionStyle}">
                                <Style.Triggers>
                                    <!-- Hide when empty -->
                                    <DataTrigger Binding="{Binding LicenseStatus}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <!-- Error → red -->
                                    <DataTrigger Binding="{Binding LicenseStatusIsError}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource RedBrush}"/>
                                    </DataTrigger>
                                    <!-- Success/info → green -->
                                    <DataTrigger Binding="{Binding LicenseStatusIsError}" Value="False">
                                        <Setter Property="Foreground" Value="{StaticResource GreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </StackPanel>
            </Border>

            <!-- About -->
            <Border Style="{StaticResource Card2Style}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding AppName}" Style="{StaticResource TextH3Style}"/>
                        <TextBlock Text="{Binding Version, StringFormat='Version {0}'}"
                                   Style="{StaticResource TextCaptionStyle}" Margin="0,2,0,4"/>
                        <TextBlock Text="{Binding CopyrightTxt}" Style="{StaticResource TextCaptionStyle}"/>
                    </StackPanel>
                    <Image Grid.Column="1" Source="/Assets/icon.ico"
                           Width="48" Height="48" VerticalAlignment="Center"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

