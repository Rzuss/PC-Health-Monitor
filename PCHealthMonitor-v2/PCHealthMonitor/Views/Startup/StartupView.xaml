<Page x:Class="PCHealthMonitor.Views.Startup.StartupView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBaseBrush}"
      Title="Startup Manager">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Startup Manager" Style="{StaticResource TextH1Style}" VerticalAlignment="Center"/>
                    <ToggleButton x:Name="Info_Startup_Manager"
                                  Width="22" Height="22" Margin="10,0,0,0"
                                  VerticalAlignment="Center" Cursor="Hand"
                                  ToolTip="What is Startup Manager?">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd" Width="22" Height="22" CornerRadius="11"
                                                    BorderBrush="{StaticResource BlueBrush}" BorderThickness="1.5"
                                                    Background="Transparent">
                                                <TextBlock Text="i" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontStyle="Italic" FontSize="12" FontWeight="Bold"
                                                           FontFamily="Georgia, serif"
                                                           Foreground="{StaticResource BlueBrush}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueGlowBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueGlowBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <Popup PlacementTarget="{Binding ElementName=Info_Startup_Manager}"
                           Placement="Bottom"
                           IsOpen="{Binding IsChecked, ElementName=Info_Startup_Manager}"
                           StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border CornerRadius="10" Padding="18,14" MaxWidth="360"
                                Background="{StaticResource BgCard2Brush}"
                                BorderBrush="{StaticResource BlueBrush}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="🚀  What is Startup Manager?"
                                           Foreground="{StaticResource BlueBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource SubTextBrush}"><Run Text="Programs listed here "/><Run FontWeight="SemiBold" Foreground="White" Text="launch automatically when Windows starts"/><Run Text=". Disabling unnecessary entries reduces boot time and frees CPU & RAM in the background."/></TextBlock>
                                    <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource SubTextBrush}"><Run FontWeight="SemiBold" Foreground="White" Text="Enabled"/><Run Text=" = starts with Windows. "/><Run FontWeight="SemiBold" Foreground="White" Text="Disabled"/><Run Text=" = skipped at boot. Changes take effect on the "/><Run FontWeight="SemiBold" Foreground="White" Text="next restart"/><Run Text="."/></TextBlock>
                                    <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource YellowBrush}" Margin="0,8,0,0">⚠  Only disable programs you recognise. System-critical entries are filtered out automatically.</TextBlock>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
                <TextBlock Text="Enable or disable programs that run when Windows starts"
                           Style="{StaticResource TextCaptionStyle}" Margin="0,2,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Refresh"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding LoadCommand}"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- Stats bar -->
        <Border Grid.Row="2" Style="{StaticResource Card2Style}">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,32,0">
                    <TextBlock Text="{Binding TotalCount}"
                               Style="{StaticResource TextMetricStyle}"
                               Foreground="{StaticResource BlueBrush}"/>
                    <TextBlock Text="Total entries" Style="{StaticResource TextCaptionStyle}"/>
                </StackPanel>
                <StackPanel Margin="0,0,32,0">
                    <TextBlock Text="{Binding EnabledCount}"
                               Style="{StaticResource TextMetricStyle}"
                               Foreground="{StaticResource GreenBrush}"/>
                    <TextBlock Text="Enabled" Style="{StaticResource TextCaptionStyle}"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="{Binding DisabledCount}"
                               Style="{StaticResource TextMetricStyle}"
                               Foreground="{StaticResource SubTextBrush}"/>
                    <TextBlock Text="Disabled" Style="{StaticResource TextCaptionStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Column headers -->
        <Grid Grid.Row="4" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="52"/>       <!-- checkbox -->
                <ColumnDefinition Width="*"/>        <!-- name -->
                <ColumnDefinition Width="160"/>      <!-- publisher -->
                <ColumnDefinition Width="80"/>       <!-- impact -->
                <ColumnDefinition Width="170"/>      <!-- action button -->
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="On"
                       Style="{StaticResource TextCaptionStyle}"
                       Margin="16,0,0,6"/>
            <TextBlock Grid.Column="1" Text="Program"
                       Style="{StaticResource TextCaptionStyle}"
                       Margin="0,0,0,6"/>
            <TextBlock Grid.Column="2" Text="Publisher"
                       Style="{StaticResource TextCaptionStyle}"
                       Margin="0,0,0,6"/>
            <TextBlock Grid.Column="3" Text="Impact"
                       Style="{StaticResource TextCaptionStyle}"
                       Margin="0,0,0,6"/>
        </Grid>

        <!-- Startup list -->
        <Border Grid.Row="5" Style="{StaticResource CardStyle}" Padding="0">
            <ListBox ItemsSource="{Binding Entries}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="RowBorder"
                                            Background="Transparent"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,2">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="RowBorder" Property="Background"
                                                    Value="{StaticResource BgCard3Brush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid MinHeight="44">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52"/>    <!-- checkbox -->
                                <ColumnDefinition Width="*"/>     <!-- name + path -->
                                <ColumnDefinition Width="160"/>   <!-- publisher -->
                                <ColumnDefinition Width="80"/>    <!-- impact -->
                                <ColumnDefinition Width="170"/>   <!-- action button -->
                            </Grid.ColumnDefinitions>

                            <!-- Toggle checkbox -->
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IsEnabled, Mode=TwoWay,
                                                          UpdateSourceTrigger=PropertyChanged}"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Margin="0"/>

                            <!-- Name + path -->
                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Margin="0,0,12,0">
                                <TextBlock Text="{Binding Name}"
                                           Style="{StaticResource TextBodyStyle}"
                                           FontWeight="Medium"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Path}"
                                           Style="{StaticResource TextCaptionStyle}"
                                           Opacity="0.5"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,1,0,0"/>
                            </StackPanel>

                            <!-- Publisher -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Publisher}"
                                       Style="{StaticResource TextBodySmStyle}"
                                       Foreground="{StaticResource SubTextBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,0,12,0"/>

                            <!-- Impact badge -->
                            <Border Grid.Column="3"
                                    CornerRadius="4"
                                    Padding="8,3"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    Background="{StaticResource BgCard3Brush}">
                                <TextBlock Text="{Binding Impact}"
                                           Style="{StaticResource TextCaptionStyle}"
                                           Foreground="{StaticResource YellowBrush}"/>
                            </Border>

                            <!-- Remove from Startup button -->
                            <Button Grid.Column="4"
                                    Content="Remove from Startup"
                                    Height="34"
                                    Padding="10,0"
                                    Margin="8,0,12,0"
                                    FontSize="11"
                                    VerticalContentAlignment="Center"
                                    VerticalAlignment="Center"
                                    IsEnabled="{Binding IsEnabled}"
                                    Command="{Binding DataContext.DisableCommand,
                                                      RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.30"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</Page>
