<Page x:Class="PCHealthMonitor.Views.Startup.StartupView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBaseBrush}"
      Title="Startup Manager">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Startup Manager" Style="{StaticResource TextH1Style}"/>
                <TextBlock Text="Enable or disable programs that run when Windows starts"
                           Style="{StaticResource TextCaptionStyle}" Margin="0,2,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Refresh"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding LoadCommand}"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- Stats bar -->
        <Border Grid.Row="2" Style="{StaticResource Card2Style}">
            <StackPanel Orientation="Horizontal" Spacing="32">
                <StackPanel>
                    <TextBlock x:Name="TotalLbl" Text="{Binding Entries.Count}"
                               Style="{StaticResource TextMetricStyle}" Foreground="{StaticResource BlueBrush}"/>
                    <TextBlock Text="Total entries" Style="{StaticResource TextCaptionStyle}"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="--" Style="{StaticResource TextMetricStyle}" Foreground="{StaticResource GreenBrush}"
                               x:Name="EnabledLbl"/>
                    <TextBlock Text="Enabled" Style="{StaticResource TextCaptionStyle}"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="--" Style="{StaticResource TextMetricStyle}" Foreground="{StaticResource SubTextBrush}"
                               x:Name="DisabledLbl"/>
                    <TextBlock Text="Disabled" Style="{StaticResource TextCaptionStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Startup list -->
        <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding Entries}"
                      Style="{StaticResource DarkDataGridStyle}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      Margin="0">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="70"/>
                    <DataGridTextColumn Header="Program"   Binding="{Binding Name}"      Width="*" MinWidth="160"/>
                    <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}"  Width="180"/>
                    <DataGridTextColumn Header="Impact"    Binding="{Binding Impact}"     Width="80"/>
                    <DataGridTextColumn Header="Path"      Binding="{Binding Path}"       Width="260"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
