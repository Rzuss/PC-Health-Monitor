<Page x:Class="PCHealthMonitor.Views.Boost.BoostView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBaseBrush}"
      Title="Boost Mode">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>  <!-- Active boost card (visible only when boosting) -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>  <!-- Process picker header + settings row -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>     <!-- Process list -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <!-- Title row with (i) button -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Boost Mode" Style="{StaticResource TextH1Style}" VerticalAlignment="Center"/>

                    <!-- Info toggle button -->
                    <ToggleButton x:Name="InfoToggle"
                                  Width="22" Height="22"
                                  Margin="10,0,0,0"
                                  VerticalAlignment="Center"
                                  Cursor="Hand"
                                  FontSize="11" FontWeight="Bold"
                                  FontFamily="Segoe UI Variable, Segoe UI"
                                  Foreground="{StaticResource BlueBrush}"
                                  ToolTip="What is Boost Mode?">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd"
                                                    Width="22" Height="22"
                                                    CornerRadius="11"
                                                    BorderBrush="{StaticResource BlueBrush}"
                                                    BorderThickness="1.5"
                                                    Background="Transparent">
                                                <TextBlock Text="i"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontStyle="Italic"
                                                           FontSize="12" FontWeight="Bold"
                                                           FontFamily="Georgia, serif"
                                                           Foreground="{StaticResource BlueBrush}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueGlowBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueGlowBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>

                    <!-- Info Popup -->
                    <Popup PlacementTarget="{Binding ElementName=InfoToggle}"
                           Placement="Bottom"
                           IsOpen="{Binding IsChecked, ElementName=InfoToggle}"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border CornerRadius="10"
                                Padding="18,14"
                                MaxWidth="360"
                                Background="{StaticResource BgCard2Brush}"
                                BorderBrush="{StaticResource BlueBrush}"
                                BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="⚡  What is Boost Mode?"
                                           Foreground="{StaticResource BlueBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           FontSize="13" FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <TextBlock TextWrapping="Wrap"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           FontSize="12" LineHeight="20"
                                           Foreground="{StaticResource SubTextBrush}">
                                    <Run FontWeight="SemiBold" Foreground="White">Boost Mode</Run>
                                    <Run Text=" elevates the selected application to"/>
                                    <Run FontWeight="SemiBold" Foreground="White"> High CPU priority</Run>
                                    <Run Text=" and"/>
                                    <Run FontWeight="SemiBold" Foreground="White"> Above Normal memory priority</Run>
                                    <Run Text=", telling Windows to allocate more processing power to it."/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           FontSize="12" LineHeight="20"
                                           Foreground="{StaticResource SubTextBrush}"
                                           Margin="0,8,0,0">
                                    <Run Text="Ideal for"/>
                                    <Run FontWeight="SemiBold" Foreground="White"> video editing, gaming, rendering</Run>
                                    <Run Text=" or any task where you need maximum performance. Priority resets automatically after the selected duration."/>
                                </TextBlock>
                                <TextBlock Text="⚠  No system files are modified — safe to use at any time."
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           FontSize="11"
                                           Foreground="{StaticResource YellowBrush}"
                                           Margin="0,10,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>

                <TextBlock Text="Select a running app and give it top CPU &amp; memory priority"
                           Style="{StaticResource TextCaptionStyle}" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Deactivate button — only visible when boosting -->
            <Button Grid.Column="1"
                    Content="⏹  Stop Boost"
                    Style="{StaticResource DangerButtonStyle}"
                    Command="{Binding DeactivateCommand}"
                    Width="130"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsVipActive, Converter={StaticResource BoolToVisibleConverter}}"/>
        </Grid>

        <!-- ── Active Boost Banner ────────────────────────────────────── -->
        <Border Grid.Row="2"
                CornerRadius="14"
                Padding="20,16"
                Visibility="{Binding IsVipActive, Converter={StaticResource BoolToVisibleConverter}}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0D2A1A" Offset="0"/>
                    <GradientStop Color="#0A1F14" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border BorderBrush="{StaticResource GreenBrush}" BorderThickness="1.5" CornerRadius="14" Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon -->
                    <Border Grid.Column="0"
                            Width="44" Height="44"
                            CornerRadius="10"
                            Background="{StaticResource GreenBrush}"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="⚡"
                                   FontSize="22"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Labels -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="BOOST ACTIVE"
                                   Style="{StaticResource TextCaptionStyle}"
                                   Foreground="{StaticResource GreenBrush}"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding ActiveProcessName}"
                                   Style="{StaticResource TextH3Style}"
                                   Margin="0,2,0,0"/>
                        <TextBlock Text="{Binding VipStatus}"
                                   Style="{StaticResource TextBodySmStyle}"
                                   Foreground="{StaticResource SubTextBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Countdown -->
                    <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="{Binding TimeRemaining}"
                                   Style="{StaticResource TextMetricStyle}"
                                   Foreground="{StaticResource GreenBrush}"
                                   FontSize="22"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="time remaining"
                                   Style="{StaticResource TextCaptionStyle}"
                                   HorizontalAlignment="Right"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- ── Picker header row ──────────────────────────────────────── -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Title + status -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Running Applications" Style="{StaticResource TextH3Style}"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Style="{StaticResource TextCaptionStyle}"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Duration label + slider (compact) -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Duration:"
                           Style="{StaticResource TextBodySmStyle}"
                           Foreground="{StaticResource SubTextBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBlock Text="{Binding BoostDurationMin}"
                           Style="{StaticResource TextBodySmStyle}"
                           Foreground="{StaticResource BlueBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock Text=" min"
                           Style="{StaticResource TextBodySmStyle}"
                           Foreground="{StaticResource SubTextBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Slider Value="{Binding BoostDurationMin}"
                        Minimum="5" Maximum="120" TickFrequency="5"
                        Width="120"
                        Style="{StaticResource DarkSliderStyle}"
                        VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Refresh -->
            <Button Grid.Column="3"
                    AutomationProperties.AutomationId="BoostRefreshBtn"
                    Content="↻  Refresh"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding RefreshCommand}"
                    Width="100"
                    Height="34"/>

            <!-- Activate -->
            <Button Grid.Column="5"
                    AutomationProperties.AutomationId="BoostActivateBtn"
                    Content="⚡  Activate Boost"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding ActivateCommand}"
                    Width="150"
                    Height="34"
                    Visibility="{Binding IsVipActive, Converter={StaticResource BoolToCollapsedConverter}}"/>
        </Grid>

        <!-- ── Process list ───────────────────────────────────────────── -->
        <Border Grid.Row="6" Style="{StaticResource CardStyle}" Padding="0">
            <Grid>
                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="0,40"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToCollapsedConverter}}">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Processes.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="No processes loaded"
                               Style="{StaticResource TextH3Style}"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource SubTextBrush}"/>
                    <TextBlock Text="Click ↻ Refresh to scan running applications"
                               Style="{StaticResource TextBodySmStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Process ListBox -->
                <ListBox ItemsSource="{Binding Processes}"
                         SelectedItem="{Binding SelectedProcess, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Row"
                                                Background="Transparent"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="16,10"
                                                Cursor="Hand">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Avatar -->
                                                <Border Grid.Column="0"
                                                        Width="32" Height="32"
                                                        CornerRadius="8"
                                                        Background="{StaticResource BgCard3Brush}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Initial}"
                                                               FontSize="14" FontWeight="SemiBold"
                                                               Foreground="{StaticResource BlueBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>

                                                <!-- Name + process name -->
                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Margin="12,0,0,0">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Style="{StaticResource TextBodyStyle}"
                                                               FontWeight="Medium"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Name}"
                                                               Style="{StaticResource TextCaptionStyle}"
                                                               Margin="0,1,0,0"
                                                               Opacity="0.6"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <!-- Memory -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding MemoryDisplay}"
                                                           Style="{StaticResource TextBodySmStyle}"
                                                           Foreground="{StaticResource SubTextBrush}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Right"/>

                                                <!-- Selected indicator -->
                                                <Border x:Name="SelectedDot"
                                                        Grid.Column="3"
                                                        Width="8" Height="8"
                                                        CornerRadius="4"
                                                        Background="{StaticResource BlueBrush}"
                                                        Margin="12,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Visibility="Hidden"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Row" Property="Background"
                                                        Value="{StaticResource BlueGlowBrush}"/>
                                                <Setter TargetName="Row" Property="BorderBrush"
                                                        Value="{StaticResource BlueBrush}"/>
                                                <Setter TargetName="Row" Property="BorderThickness"
                                                        Value="3,0,0,1"/>
                                                <Setter TargetName="SelectedDot" Property="Visibility"
                                                        Value="Visible"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Row" Property="Background"
                                                        Value="{StaticResource BgCard3Brush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Page>
