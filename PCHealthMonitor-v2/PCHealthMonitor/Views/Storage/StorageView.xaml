<Page x:Class="PCHealthMonitor.Views.Storage.StorageView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBaseBrush}"
      Title="Storage Analyzer">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Storage Analyzer" Style="{StaticResource TextH1Style}" VerticalAlignment="Center"/>
                    <ToggleButton x:Name="Info_Storage_Analyzer"
                                  Width="22" Height="22" Margin="10,0,0,0"
                                  VerticalAlignment="Center" Cursor="Hand"
                                  ToolTip="What is Storage Analyzer?">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd" Width="22" Height="22" CornerRadius="11"
                                                    BorderBrush="{StaticResource BlueBrush}" BorderThickness="1.5"
                                                    Background="Transparent">
                                                <TextBlock Text="i" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontStyle="Italic" FontSize="12" FontWeight="Bold"
                                                           FontFamily="Georgia, serif"
                                                           Foreground="{StaticResource BlueBrush}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueGlowBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueGlowBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <Popup PlacementTarget="{Binding ElementName=Info_Storage_Analyzer}"
                           Placement="Bottom"
                           IsOpen="{Binding IsChecked, ElementName=Info_Storage_Analyzer}"
                           StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border CornerRadius="10" Padding="18,14" MaxWidth="360"
                                Background="{StaticResource BgCard2Brush}"
                                BorderBrush="{StaticResource BlueBrush}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="💾  What is Storage Analyzer?"
                                           Foreground="{StaticResource BlueBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource SubTextBrush}"><Run Text="Finds the "/><Run FontWeight="SemiBold" Foreground="White" Text="largest files and folders"/><Run Text=" on your selected drive — helping you locate space hogs quickly without manually browsing every directory."/></TextBlock>
                                    <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource SubTextBrush}"><Run Text="Click "/><Run FontWeight="SemiBold" Foreground="White" Text="Find Large Items"/><Run Text=" to scan, then "/><Run FontWeight="SemiBold" Foreground="White" Text="double-click"/><Run Text=" any row to open it directly in Windows Explorer for easy manual cleanup."/></TextBlock>
                                    <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource GreenBrush}" Margin="0,8,0,0">✓  Read-only scan — nothing is deleted automatically.</TextBlock>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
                <TextBlock AutomationProperties.AutomationId="StorageStatusText"
                           Text="{Binding StatusText}"
                           Style="{StaticResource TextCaptionStyle}"
                           Margin="0,2,0,0"/>
            </StackPanel>
            <Button Grid.Column="1"
                    AutomationProperties.AutomationId="StorageScanBtn"
                    Content="Find Large Items"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding ScanCommand}"
                    Width="150"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- Drive cards — selectable ListBox -->
        <ListBox Grid.Row="2"
                 AutomationProperties.AutomationId="StorageDrivesList"
                 ItemsSource="{Binding Drives}"
                 SelectedItem="{Binding SelectedDrive, Mode=TwoWay}"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,12,0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="CardBorder"
                                        Width="210"
                                        Background="{StaticResource BgCard2Brush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="16"
                                        Cursor="Hand">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource TextH3Style}"/>
                                        <TextBlock Text="{Binding DriveType}"
                                                   Style="{StaticResource TextCaptionStyle}"
                                                   Margin="0,2,0,8"/>
                                        <ProgressBar Value="{Binding UsedPct, Mode=OneWay}"
                                                     Maximum="100"
                                                     Height="6"
                                                     Style="{StaticResource DarkProgressBarStyle}"
                                                     Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding UsedDisplay}"
                                                   Style="{StaticResource TextBodySmStyle}"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="CardBorder"
                                                Property="BorderBrush"
                                                Value="{StaticResource BlueBrush}"/>
                                        <Setter TargetName="CardBorder"
                                                Property="BorderThickness"
                                                Value="2"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CardBorder"
                                                Property="Background"
                                                Value="{StaticResource BgCard3Brush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- Largest Files & Folders table -->
        <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,14,16,0">
                    <TextBlock Text="Largest Files &amp; Folders"
                               Style="{StaticResource TextH3Style}"/>
                    <TextBlock Text=" — select a drive above and click Find Large Items"
                               Style="{StaticResource TextCaptionStyle}"
                               VerticalAlignment="Bottom"
                               Margin="8,0,0,2"/>
                </StackPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding LargeItems}"
                          Style="{StaticResource DarkDataGridStyle}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Margin="0,8,0,0"
                          MouseDoubleClick="LargeItemsGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name"
                                            Binding="{Binding Name}"
                                            Width="*"
                                            MinWidth="180"/>
                        <DataGridTextColumn Header="Type"
                                            Binding="{Binding TypeDisplay}"
                                            Width="80"/>
                        <DataGridTextColumn Header="Size"
                                            Binding="{Binding SizeDisplay}"
                                            Width="100"/>
                        <DataGridTextColumn Header="Path"
                                            Binding="{Binding Path}"
                                            Width="320"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
