<Page x:Class="PCHealthMonitor.Views.Network.NetworkView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBaseBrush}"
      Title="Network">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Network" Style="{StaticResource TextH1Style}" VerticalAlignment="Center"/>
                    <ToggleButton x:Name="Info_Network"
                                  Width="22" Height="22" Margin="10,0,0,0"
                                  VerticalAlignment="Center" Cursor="Hand"
                                  ToolTip="What is Network Monitor?">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd" Width="22" Height="22" CornerRadius="11"
                                                    BorderBrush="{StaticResource BlueBrush}" BorderThickness="1.5"
                                                    Background="Transparent">
                                                <TextBlock Text="i" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontStyle="Italic" FontSize="12" FontWeight="Bold"
                                                           FontFamily="Georgia, serif"
                                                           Foreground="{StaticResource BlueBrush}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueGlowBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueGlowBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <Popup PlacementTarget="{Binding ElementName=Info_Network}"
                           Placement="Bottom"
                           IsOpen="{Binding IsChecked, ElementName=Info_Network}"
                           StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border CornerRadius="10" Padding="18,14" MaxWidth="360"
                                Background="{StaticResource BgCard2Brush}"
                                BorderBrush="{StaticResource BlueBrush}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="🌐  What is Network Monitor?"
                                           Foreground="{StaticResource BlueBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource SubTextBrush}"><Run Text="Scans your active network and displays your "/><Run FontWeight="SemiBold" Foreground="White" Text="local IP, public IP, active interfaces"/><Run Text=", and open listening ports."/></TextBlock>
                                    <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource SubTextBrush}"><Run Text="Use it to "/><Run FontWeight="SemiBold" Foreground="White" Text="identify unexpected connections"/><Run Text=", verify your adapter configuration, or check which services are exposed on your machine. Click "/><Run FontWeight="SemiBold" Foreground="White" Text="Scan"/><Run Text=" to refresh."/></TextBlock>
                                    <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" LineHeight="20" TextWrapping="Wrap" Foreground="{StaticResource YellowBrush}" Margin="0,8,0,0">⚠  Open ports are informational only — this tool does not close or block any connections.</TextBlock>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource TextCaptionStyle}" Margin="0,2,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Scan"
                    AutomationProperties.AutomationId="NetworkScanBtn"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding ScanCommand}" Width="100"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- Stats row -->
        <UniformGrid Grid.Row="2" Rows="1" Columns="3">
            <Border Style="{StaticResource Card2Style}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="PUBLIC IP" Style="{StaticResource TextLabelStyle}" Margin="0,0,0,6"/>
                    <TextBlock AutomationProperties.AutomationId="NetworkPublicIp" Text="{Binding PublicIp}" Style="{StaticResource TextMetricStyle}" FontSize="16"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card2Style}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="DOWNLOAD" Style="{StaticResource TextLabelStyle}" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding DownloadDisplay}"
                               Style="{StaticResource TextMetricStyle}" FontSize="18"
                               Foreground="{StaticResource GreenBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card2Style}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="UPLOAD" Style="{StaticResource TextLabelStyle}" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding UploadDisplay}"
                               Style="{StaticResource TextMetricStyle}" FontSize="18"
                               Foreground="{StaticResource BlueBrush}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Active connections table -->
        <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Active Connections"
                           Style="{StaticResource TextH3Style}" Margin="16,14,0,0"/>
                <DataGrid Grid.Row="1"
                          AutomationProperties.AutomationId="NetworkConnectionsGrid"
                          ItemsSource="{Binding Connections}"
                          Style="{StaticResource DarkDataGridStyle}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Margin="0,8,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Protocol"    Binding="{Binding Protocol}"    Width="70"/>
                        <DataGridTextColumn Header="Local Port"  Binding="{Binding LocalPort}"   Width="90"/>
                        <DataGridTextColumn Header="Remote"      Binding="{Binding RemoteAddr}"  Width="160"/>
                        <DataGridTextColumn Header="Port"        Binding="{Binding RemotePort}"  Width="70"/>
                        <DataGridTextColumn Header="State"       Binding="{Binding State}"       Width="110"/>
                        <DataGridTextColumn Header="Process"     Binding="{Binding ProcessName}" Width="*" MinWidth="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
