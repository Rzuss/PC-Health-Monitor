<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         DEEP SPACE — Animation System v2.0
         Durations: micro=150ms, normal=200ms, slow=300ms
         Easing:    EaseOut for enter, EaseIn for exit
    ═══════════════════════════════════════════════════════════ -->

    <!-- ─── Easing Functions ─────────────────────────────────── -->
    <CubicEase x:Key="EaseOut" EasingMode="EaseOut"/>
    <CubicEase x:Key="EaseIn"  EasingMode="EaseIn"/>
    <CubicEase x:Key="EaseInOut" EasingMode="EaseInOut"/>
    <ElasticEase x:Key="SpringEase" EasingMode="EaseOut" Oscillations="1" Springiness="6"/>
    <BackEase x:Key="BackEaseOut" EasingMode="EaseOut" Amplitude="0.4"/>

    <!-- ─── Durations ────────────────────────────────────────── -->
    <Duration x:Key="DurationMicro">0:0:0.150</Duration>
    <Duration x:Key="DurationNormal">0:0:0.200</Duration>
    <Duration x:Key="DurationSlow">0:0:0.300</Duration>
    <Duration x:Key="DurationXSlow">0:0:0.400</Duration>

    <!-- ─── Fade In ──────────────────────────────────────────── -->
    <Storyboard x:Key="FadeInStoryboard">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1"
                         Duration="{StaticResource DurationNormal}"
                         EasingFunction="{StaticResource EaseOut}"/>
    </Storyboard>

    <!-- ─── Fade Out ─────────────────────────────────────────── -->
    <Storyboard x:Key="FadeOutStoryboard">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="1" To="0"
                         Duration="{StaticResource DurationMicro}"
                         EasingFunction="{StaticResource EaseIn}"/>
    </Storyboard>

    <!-- ─── Slide In from Bottom ─────────────────────────────── -->
    <Storyboard x:Key="SlideInFromBottomStoryboard">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1"
                         Duration="{StaticResource DurationSlow}"
                         EasingFunction="{StaticResource EaseOut}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                         From="20" To="0"
                         Duration="{StaticResource DurationSlow}"
                         EasingFunction="{StaticResource EaseOut}"/>
    </Storyboard>

    <!-- ─── Slide In from Right (navigation forward) ─────────── -->
    <Storyboard x:Key="SlideInFromRightStoryboard">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1"
                         Duration="{StaticResource DurationSlow}"
                         EasingFunction="{StaticResource EaseOut}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                         From="40" To="0"
                         Duration="{StaticResource DurationSlow}"
                         EasingFunction="{StaticResource EaseOut}"/>
    </Storyboard>

    <!-- ─── Slide In from Left (navigation back) ─────────────── -->
    <Storyboard x:Key="SlideInFromLeftStoryboard">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1"
                         Duration="{StaticResource DurationSlow}"
                         EasingFunction="{StaticResource EaseOut}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                         From="-40" To="0"
                         Duration="{StaticResource DurationSlow}"
                         EasingFunction="{StaticResource EaseOut}"/>
    </Storyboard>

    <!-- ─── Scale In (card expand) ───────────────────────────── -->
    <Storyboard x:Key="ScaleInStoryboard">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1"
                         Duration="{StaticResource DurationNormal}"
                         EasingFunction="{StaticResource EaseOut}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                         From="0.95" To="1"
                         Duration="{StaticResource DurationNormal}"
                         EasingFunction="{StaticResource BackEaseOut}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                         From="0.95" To="1"
                         Duration="{StaticResource DurationNormal}"
                         EasingFunction="{StaticResource BackEaseOut}"/>
    </Storyboard>

    <!-- ─── Scale Out ────────────────────────────────────────── -->
    <Storyboard x:Key="ScaleOutStoryboard">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="1" To="0"
                         Duration="{StaticResource DurationMicro}"
                         EasingFunction="{StaticResource EaseIn}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                         From="1" To="0.95"
                         Duration="{StaticResource DurationMicro}"
                         EasingFunction="{StaticResource EaseIn}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                         From="1" To="0.95"
                         Duration="{StaticResource DurationMicro}"
                         EasingFunction="{StaticResource EaseIn}"/>
    </Storyboard>

    <!-- ─── Pulse (accent highlight — used on scan button) ───── -->
    <Storyboard x:Key="PulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0.6" To="1.0"
                         Duration="{StaticResource DurationXSlow}"
                         EasingFunction="{StaticResource EaseInOut}"/>
    </Storyboard>

    <!-- ─── Spin (loading indicator) ─────────────────────────── -->
    <Storyboard x:Key="SpinStoryboard" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                         From="0" To="360"
                         Duration="0:0:1"
                         EasingFunction="{x:Null}"/>
    </Storyboard>

    <!-- ─── Progress Fill (used on health score arc) ──────────── -->
    <Storyboard x:Key="ProgressFillStoryboard">
        <DoubleAnimation Storyboard.TargetProperty="Value"
                         From="0"
                         Duration="{StaticResource DurationXSlow}"
                         EasingFunction="{StaticResource EaseOut}"/>
    </Storyboard>

    <!-- ─── Number Count-Up (opacity fade while value changes) ── -->
    <Storyboard x:Key="NumberRevealStoryboard">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1"
                         Duration="{StaticResource DurationNormal}"
                         EasingFunction="{StaticResource EaseOut}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                         From="8" To="0"
                         Duration="{StaticResource DurationNormal}"
                         EasingFunction="{StaticResource EaseOut}"/>
    </Storyboard>

    <!-- ─── Sidebar Expand / Collapse ───────────────────────── -->
    <Storyboard x:Key="SidebarExpandStoryboard">
        <DoubleAnimation Storyboard.TargetProperty="Width"
                         To="220"
                         Duration="{StaticResource DurationSlow}"
                         EasingFunction="{StaticResource EaseOut}"/>
    </Storyboard>

    <Storyboard x:Key="SidebarCollapseStoryboard">
        <DoubleAnimation Storyboard.TargetProperty="Width"
                         To="64"
                         Duration="{StaticResource DurationSlow}"
                         EasingFunction="{StaticResource EaseOut}"/>
    </Storyboard>

    <!-- ─── Toast Slide-In (bottom right) ───────────────────── -->
    <Storyboard x:Key="ToastEnterStoryboard">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1"
                         Duration="{StaticResource DurationNormal}"
                         EasingFunction="{StaticResource EaseOut}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                         From="20" To="0"
                         Duration="{StaticResource DurationNormal}"
                         EasingFunction="{StaticResource EaseOut}"/>
    </Storyboard>

    <Storyboard x:Key="ToastExitStoryboard">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="1" To="0"
                         Duration="{StaticResource DurationMicro}"
                         EasingFunction="{StaticResource EaseIn}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                         From="0" To="10"
                         Duration="{StaticResource DurationMicro}"
                         EasingFunction="{StaticResource EaseIn}"/>
    </Storyboard>

    <!-- ─── Score Ring Arc animation (used in code-behind) ───── -->
    <!-- Storyboard x:Key="ArcDrawStoryboard" — driven by DoubleAnimationUsingKeyFrames
         on the ArcSegment.Point + angle; defined in code-behind for WPF path geometry -->

</ResourceDictionary>
