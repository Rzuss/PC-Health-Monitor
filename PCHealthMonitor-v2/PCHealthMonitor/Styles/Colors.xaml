<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         DEEP SPACE — Color System v2.0
         Matches the PowerShell v1 palette exactly
    ═══════════════════════════════════════════════════════════ -->

    <!-- Backgrounds -->
    <Color x:Key="BgBaseColor">#0D0D0F</Color>
    <Color x:Key="BgCardColor">#161619</Color>
    <Color x:Key="BgCard2Color">#121214</Color>
    <Color x:Key="BgCard3Color">#1C1C20</Color>

    <!-- Accents -->
    <Color x:Key="BlueColor">#6C63FF</Color>
    <Color x:Key="PurpleColor">#8B7CF8</Color>
    <Color x:Key="GreenColor">#30D158</Color>
    <Color x:Key="YellowColor">#FF9F0A</Color>
    <Color x:Key="RedColor">#FF3B30</Color>
    <Color x:Key="OrangeColor">#FF6B35</Color>

    <!-- Text -->
    <Color x:Key="TextColor">#F5F5F7</Color>
    <Color x:Key="SubTextColor">#8E8E93</Color>
    <Color x:Key="DimColor">#3A3A3C</Color>

    <!-- Borders -->
    <Color x:Key="BorderColor">#2C2C2E</Color>

    <!-- Glow / transparent accents -->
    <Color x:Key="BlueGlowColor">#376C63FF</Color>
    <Color x:Key="GreenGlowColor">#2230D158</Color>
    <Color x:Key="RedGlowColor">#22FF3B30</Color>
    <Color x:Key="YellowGlowColor">#22FF9F0A</Color>

    <!-- ─── SolidColorBrushes ─────────────────────────────────── -->
    <SolidColorBrush x:Key="BgBaseBrush"   Color="{StaticResource BgBaseColor}"/>
    <SolidColorBrush x:Key="BgCardBrush"   Color="{StaticResource BgCardColor}"/>
    <SolidColorBrush x:Key="BgCard2Brush"  Color="{StaticResource BgCard2Color}"/>
    <SolidColorBrush x:Key="BgCard3Brush"  Color="{StaticResource BgCard3Color}"/>
    <SolidColorBrush x:Key="BlueBrush"     Color="{StaticResource BlueColor}"/>
    <SolidColorBrush x:Key="PurpleBrush"   Color="{StaticResource PurpleColor}"/>
    <SolidColorBrush x:Key="GreenBrush"    Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="YellowBrush"   Color="{StaticResource YellowColor}"/>
    <SolidColorBrush x:Key="RedBrush"      Color="{StaticResource RedColor}"/>
    <SolidColorBrush x:Key="TextBrush"     Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SubTextBrush"  Color="{StaticResource SubTextColor}"/>
    <SolidColorBrush x:Key="DimBrush"      Color="{StaticResource DimColor}"/>
    <SolidColorBrush x:Key="BorderBrush"   Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BlueGlowBrush" Color="{StaticResource BlueGlowColor}"/>

    <!-- Score tier brushes -->
    <SolidColorBrush x:Key="ScoreExcellentBrush" Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="ScoreGoodBrush"       Color="#30D158"/>
    <SolidColorBrush x:Key="ScoreFairBrush"        Color="{StaticResource YellowColor}"/>
    <SolidColorBrush x:Key="ScorePoorBrush"        Color="#FF6B35"/>
    <SolidColorBrush x:Key="ScoreCriticalBrush"    Color="{StaticResource RedColor}"/>

    <!-- Transparent -->
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>

</ResourceDictionary>
