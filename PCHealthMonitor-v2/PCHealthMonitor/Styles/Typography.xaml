<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         DEEP SPACE — Typography System v2.0
         Font: Segoe UI Variable (Win 11 default) → fallback Segoe UI
    ═══════════════════════════════════════════════════════════ -->

    <!-- ─── Font Family ──────────────────────────────────────── -->
    <FontFamily x:Key="PrimaryFont">Segoe UI Variable, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Code, Consolas, monospace</FontFamily>

    <!-- ─── Font Sizes ───────────────────────────────────────── -->
    <sys:Double x:Key="FontSizeXS"   xmlns:sys="clr-namespace:System;assembly=mscorlib">10</sys:Double>
    <sys:Double x:Key="FontSizeSM"   xmlns:sys="clr-namespace:System;assembly=mscorlib">12</sys:Double>
    <sys:Double x:Key="FontSizeMD"   xmlns:sys="clr-namespace:System;assembly=mscorlib">13</sys:Double>
    <sys:Double x:Key="FontSizeBase" xmlns:sys="clr-namespace:System;assembly=mscorlib">14</sys:Double>
    <sys:Double x:Key="FontSizeLG"   xmlns:sys="clr-namespace:System;assembly=mscorlib">16</sys:Double>
    <sys:Double x:Key="FontSizeXL"   xmlns:sys="clr-namespace:System;assembly=mscorlib">20</sys:Double>
    <sys:Double x:Key="FontSize2XL"  xmlns:sys="clr-namespace:System;assembly=mscorlib">24</sys:Double>
    <sys:Double x:Key="FontSize3XL"  xmlns:sys="clr-namespace:System;assembly=mscorlib">32</sys:Double>
    <sys:Double x:Key="FontSize4XL"  xmlns:sys="clr-namespace:System;assembly=mscorlib">48</sys:Double>

    <!-- ─── Text Styles ─────────────────────────────────────── -->

    <!-- Display: hero numbers (CPU %, scores) -->
    <Style x:Key="TextDisplayStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize"     Value="{StaticResource FontSize4XL}"/>
        <Setter Property="FontWeight"   Value="Bold"/>
        <Setter Property="Foreground"   Value="{StaticResource TextBrush}"/>
        <Setter Property="LineHeight"   Value="52"/>
    </Style>

    <!-- H1: Page titles -->
    <Style x:Key="TextH1Style" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize"     Value="{StaticResource FontSize3XL}"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Foreground"   Value="{StaticResource TextBrush}"/>
    </Style>

    <!-- H2: Section titles -->
    <Style x:Key="TextH2Style" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize"     Value="{StaticResource FontSize2XL}"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Foreground"   Value="{StaticResource TextBrush}"/>
    </Style>

    <!-- H3: Card titles -->
    <Style x:Key="TextH3Style" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize"     Value="{StaticResource FontSizeLG}"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Foreground"   Value="{StaticResource TextBrush}"/>
    </Style>

    <!-- Body: Default body text -->
    <Style x:Key="TextBodyStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize"     Value="{StaticResource FontSizeBase}"/>
        <Setter Property="FontWeight"   Value="Normal"/>
        <Setter Property="Foreground"   Value="{StaticResource TextBrush}"/>
        <Setter Property="LineHeight"   Value="22"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- BodySM: Small body / table cells -->
    <Style x:Key="TextBodySmStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize"     Value="{StaticResource FontSizeMD}"/>
        <Setter Property="FontWeight"   Value="Normal"/>
        <Setter Property="Foreground"   Value="{StaticResource TextBrush}"/>
        <Setter Property="LineHeight"   Value="20"/>
    </Style>

    <!-- Caption: Sub-labels, timestamps -->
    <Style x:Key="TextCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize"     Value="{StaticResource FontSizeSM}"/>
        <Setter Property="FontWeight"   Value="Normal"/>
        <Setter Property="Foreground"   Value="{StaticResource SubTextBrush}"/>
    </Style>

    <!-- Label: Uppercase section labels -->
    <Style x:Key="TextLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"    Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize"      Value="{StaticResource FontSizeXS}"/>
        <Setter Property="FontWeight"    Value="SemiBold"/>
        <Setter Property="Foreground"    Value="{StaticResource SubTextBrush}"/>
        <Setter Property="CharacterSpacing" Value="100"/>
    </Style>

    <!-- Mono: Log output, file paths -->
    <Style x:Key="TextMonoStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize"     Value="{StaticResource FontSizeSM}"/>
        <Setter Property="FontWeight"   Value="Normal"/>
        <Setter Property="Foreground"   Value="{StaticResource SubTextBrush}"/>
    </Style>

    <!-- Metric: Big stat numbers on cards (with accent color override) -->
    <Style x:Key="TextMetricStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize"     Value="{StaticResource FontSize2XL}"/>
        <Setter Property="FontWeight"   Value="Bold"/>
        <Setter Property="Foreground"   Value="{StaticResource TextBrush}"/>
    </Style>

    <!-- Sidebar item label -->
    <Style x:Key="TextSidebarStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize"     Value="{StaticResource FontSizeBase}"/>
        <Setter Property="FontWeight"   Value="Normal"/>
        <Setter Property="Foreground"   Value="{StaticResource SubTextBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Score large number -->
    <Style x:Key="TextScoreStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize"     Value="{StaticResource FontSize4XL}"/>
        <Setter Property="FontWeight"   Value="Bold"/>
        <Setter Property="Foreground"   Value="{StaticResource GreenBrush}"/>
    </Style>

</ResourceDictionary>
