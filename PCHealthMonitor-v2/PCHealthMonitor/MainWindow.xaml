<Window x:Class="PCHealthMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:vm="clr-namespace:PCHealthMonitor.ViewModels"
        Title="PC Health Monitor"
        Width="1200" Height="780"
        MinWidth="960" MinHeight="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        SnapsToDevicePixels="True">

    <!-- System tray icon -->
    <Window.Resources>
        <tb:TaskbarIcon x:Key="TrayIcon"
                        IconSource="/Assets/icon.ico"
                        ToolTipText="PC Health Monitor"
                        TrayLeftMouseDown="TrayIcon_LeftMouseDown">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open"   Click="TrayMenu_Open"/>
                    <MenuItem Header="Scan Now" Click="TrayMenu_Scan"/>
                    <Separator/>
                    <MenuItem Header="Exit"   Click="TrayMenu_Exit"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Window.Resources>

    <!-- Outer chrome border -->
    <Border Background="{StaticResource BgBaseBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            ClipToBounds="True">

        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.8"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>   <!-- Custom title bar -->
                <RowDefinition Height="*"/>    <!-- Main content -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" x:Name="SidebarColumn"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── Custom Title Bar ─────────────────────────────────── -->
            <Border Grid.Row="0" Grid.ColumnSpan="2"
                    Background="{StaticResource BgCard2Brush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo + App name -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="16,0">
                        <Image Source="/Assets/icon.ico" Width="22" Height="22" Margin="0,0,8,0"/>
                        <TextBlock Text="PC Health Monitor"
                                   Style="{StaticResource TextH3Style}"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <Border Background="{StaticResource BlueBrush}"
                                CornerRadius="4"
                                Padding="6,2"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="PRO"
                                       Foreground="White"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       FontFamily="Segoe UI Variable, Segoe UI"
                                       x:Name="ProBadge"
                                       Visibility="Collapsed"/>
                        </Border>
                    </StackPanel>

                    <!-- Center: scan status text -->
                    <TextBlock Grid.Column="1"
                               x:Name="StatusText"
                               Text="System is healthy"
                               Style="{StaticResource TextCaptionStyle}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0">
                        <Button x:Name="MinimizeBtn"
                                Style="{StaticResource IconButtonStyle}"
                                Width="40" Height="40"
                                Click="MinimizeBtn_Click"
                                ToolTip="Minimize to tray">
                            <Path Data="M 8 0 L 16 0" Stroke="{StaticResource SubTextBrush}" StrokeThickness="1.5"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="MaximizeBtn"
                                Style="{StaticResource IconButtonStyle}"
                                Width="40" Height="40"
                                Click="MaximizeBtn_Click"
                                ToolTip="Maximize">
                            <Path x:Name="MaximizePath"
                                  Data="M 2 2 L 14 2 L 14 14 L 2 14 Z"
                                  Stroke="{StaticResource SubTextBrush}" StrokeThickness="1.5" Fill="Transparent"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="CloseBtn"
                                Style="{StaticResource IconButtonStyle}"
                                Width="40" Height="40"
                                Click="CloseBtn_Click"
                                ToolTip="Close">
                            <Path Data="M 2 2 L 14 14 M 14 2 L 2 14"
                                  Stroke="{StaticResource SubTextBrush}" StrokeThickness="1.5"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ─── Sidebar ──────────────────────────────────────────── -->
            <Border Grid.Row="1" Grid.Column="0"
                    Background="{StaticResource BgCard2Brush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <!-- Grid layout: Row 0 = nav, Row 1+3 = equal flexible spacers, Row 2 = banner centered -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Nav items -->
                        <RowDefinition Height="*"/>     <!-- Spacer above banner -->
                        <RowDefinition Height="Auto"/>  <!-- Banner -->
                        <RowDefinition Height="*"/>     <!-- Spacer below banner (equal → centered) -->
                    </Grid.RowDefinitions>

                    <!-- Nav items -->
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Hidden">
                        <StackPanel x:Name="NavPanel" Margin="8,12,8,0">
                            <!-- Dashboard -->
                            <Button x:Name="NavDashboard"
                                    AutomationProperties.AutomationId="NavDashboard"
                                    Tag="Dashboard"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="NavBtn_Click"
                                    Margin="0,2"
                                    Height="44" HorizontalContentAlignment="Left"
                                    Padding="12,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="16" Height="16" Margin="0,0,10,0"
                                          Data="M 2 10 L 8 2 L 14 10 M 4 10 L 4 14 L 12 14 L 12 10"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="1.5" Fill="Transparent"/>
                                    <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Startup Manager -->
                            <Button Tag="Startup" AutomationProperties.AutomationId="NavStartup" Style="{StaticResource SecondaryButtonStyle}"
                                    Click="NavBtn_Click" Margin="0,2" Height="44"
                                    HorizontalContentAlignment="Left" Padding="12,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="16" Height="16" Margin="0,0,10,0"
                                          Data="M 2 4 L 14 4 M 2 8 L 10 8 M 2 12 L 12 12"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="1.5"/>
                                    <TextBlock Text="Startup Manager" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Junk Cleaner -->
                            <Button Tag="JunkCleaner" AutomationProperties.AutomationId="NavJunkCleaner" Style="{StaticResource SecondaryButtonStyle}"
                                    Click="NavBtn_Click" Margin="0,2" Height="44"
                                    HorizontalContentAlignment="Left" Padding="12,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="16" Height="16" Margin="0,0,10,0"
                                          Data="M 4 4 L 12 4 L 11 14 L 5 14 Z M 2 4 L 14 4 M 6 2 L 10 2"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="1.5" Fill="Transparent"/>
                                    <TextBlock Text="Junk Cleaner" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Storage Analyzer -->
                            <Button Tag="Storage" AutomationProperties.AutomationId="NavStorage" Style="{StaticResource SecondaryButtonStyle}"
                                    Click="NavBtn_Click" Margin="0,2" Height="44"
                                    HorizontalContentAlignment="Left" Padding="12,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="16" Height="16" Margin="0,0,10,0"
                                          Data="M 2 4 L 14 4 L 14 12 L 2 12 Z M 2 8 L 14 8"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="1.5" Fill="Transparent"/>
                                    <TextBlock Text="Storage Analyzer" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Boost Mode -->
                            <Button Tag="Boost" AutomationProperties.AutomationId="NavBoost" Style="{StaticResource SecondaryButtonStyle}"
                                    Click="NavBtn_Click" Margin="0,2" Height="44"
                                    HorizontalContentAlignment="Left" Padding="12,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="16" Height="16" Margin="0,0,10,0"
                                          Data="M 8 2 L 4 9 L 7 9 L 6 14 L 12 7 L 9 7 Z"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="1.5" Fill="Transparent"/>
                                    <TextBlock Text="Boost Mode" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- System Info -->
                            <Button Tag="DiskHealth" AutomationProperties.AutomationId="NavDiskHealth" Style="{StaticResource SecondaryButtonStyle}"
                                    Click="NavBtn_Click" Margin="0,2" Height="44"
                                    HorizontalContentAlignment="Left" Padding="12,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="16" Height="16" Margin="0,0,10,0"
                                          Data="M 8 2 L 8 2.5 M 4 4 L 12 4 L 13 13 L 3 13 Z M 6 7 L 10 7 M 6 10 L 9 10"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="1.5" Fill="Transparent"/>
                                    <TextBlock Text="System Info" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Tools -->
                            <Button Tag="Tools" AutomationProperties.AutomationId="NavTools" Style="{StaticResource SecondaryButtonStyle}"
                                    Click="NavBtn_Click" Margin="0,2" Height="44"
                                    HorizontalContentAlignment="Left" Padding="12,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="16" Height="16" Margin="0,0,10,0"
                                          Data="M 10 2 L 10 5 L 12 7 L 14 5 L 12 3 Z M 2 14 L 8 8"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="1.5"/>
                                    <TextBlock Text="Tools" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Network -->
                            <Button Tag="Network" AutomationProperties.AutomationId="NavNetwork" Style="{StaticResource SecondaryButtonStyle}"
                                    Click="NavBtn_Click" Margin="0,2" Height="44"
                                    HorizontalContentAlignment="Left" Padding="12,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="16" Height="16" Margin="0,0,10,0"
                                          Data="M 8 2 A 6 6 0 1 1 8 14 A 6 6 0 1 1 8 2 M 2 8 L 14 8 M 8 2 C 6 5 6 11 8 14"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="1.5"/>
                                    <TextBlock Text="Network" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Separator -->
                            <Separator Margin="4,8"/>

                            <!-- Settings -->
                            <Button Tag="Settings" AutomationProperties.AutomationId="NavSettings" Style="{StaticResource SecondaryButtonStyle}"
                                    Click="NavBtn_Click" Margin="0,2" Height="44"
                                    HorizontalContentAlignment="Left" Padding="12,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="16" Height="16" Margin="0,0,10,0"
                                          Data="M 8 6 A 2 2 0 1 1 8 10 A 2 2 0 1 1 8 6 M 8 2 L 8 4 M 8 12 L 8 14 M 2 8 L 4 8 M 12 8 L 14 8"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="1.5"/>
                                    <TextBlock Text="Settings" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Upgrade banner — Row 2, centered between nav and bottom -->
                    <Border Grid.Row="2"
                            Margin="14,0,14,0"
                            CornerRadius="10"
                            Padding="14,11"
                            x:Name="UpgradeBanner">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#5B54E8" Offset="0"/>
                                <GradientStop Color="#7C6FF5" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="✦" Foreground="#FFD580" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Upgrade to Pro"
                                               Foreground="White" FontWeight="SemiBold" FontSize="13"
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="$9.99" HorizontalAlignment="Right"
                                           Foreground="#BDB8FF" FontSize="11"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <Button Content="Get Pro  →"
                                    Height="28"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    FontFamily="Segoe UI Variable, Segoe UI"
                                    Background="White"
                                    Foreground="#5B54E8"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="GetProBtn_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F0EEFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                </Grid>
            </Border>

            <!-- ─── Main Content Area ────────────────────────────────── -->
            <Frame Grid.Row="1" Grid.Column="1"
                   x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"
                   JournalOwnership="OwnsJournal"
                   Background="Transparent"/>

            <!-- ─── Toast Overlay ────────────────────────────────────── -->
            <!-- Spans full content area (row 1 only, above sidebar too).
                 IsHitTestVisible=False on the host so toasts never block
                 clicks; individual toast cards enable hit-testing for
                 the dismiss button. -->
            <Grid Grid.Row="1" Grid.ColumnSpan="2"
                  IsHitTestVisible="False"
                  Panel.ZIndex="999">
                <ItemsControl x:Name="ToastPanel"
                              VerticalAlignment="Bottom"
                              HorizontalAlignment="Right"
                              Margin="0,0,24,24"
                              IsHitTestVisible="True"
                              Width="320">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>

        </Grid>
    </Border>
</Window>
